{
  "$schema": "gaboma-design-tokens-v3",
  "$description": "Gaboma AI Design System V3 — Source unique cross-plateforme (Web, Android, iOS)",

  "typography": {
    "scale": "major-third-1.25",
    "base": 16,
    "fonts": {
      "display": "Outfit",
      "body": "Sora",
      "mono": "JetBrains Mono"
    },
    "levels": {
      "caption":     { "size": 12, "lineHeight": 16, "font": "body", "weight": 400, "letterSpacing": 0 },
      "small-meta":  { "size": 13, "lineHeight": 18, "font": "body", "weight": 500, "letterSpacing": 0.02 },
      "body":        { "size": 16, "lineHeight": 24, "font": "body", "weight": 500, "letterSpacing": 0 },
      "body-large":  { "size": 18, "lineHeight": 28, "font": "body", "weight": 400, "letterSpacing": 0 },
      "label-h4":    { "size": 20, "lineHeight": 26, "font": "display", "weight": 600, "letterSpacing": -0.01 },
      "h3":          { "size": 25, "lineHeight": 32, "font": "display", "weight": 600, "letterSpacing": -0.015 },
      "h2":          { "size": 32, "lineHeight": 40, "font": "display", "weight": 600, "letterSpacing": -0.02 },
      "h1":          { "size": 40, "lineHeight": 48, "font": "display", "weight": 600, "letterSpacing": -0.025 },
      "code-inline": { "size": 13, "lineHeight": 20, "font": "mono", "weight": 400, "letterSpacing": 0 },
      "code-block":  { "size": 14, "lineHeight": 22, "font": "mono", "weight": 400, "letterSpacing": 0 }
    },
    "letterSpacingSpecial": {
      "eyebrow-caps": "0.06em to 0.08em",
      "buttons": "0.01em",
      "metadata": "0.02em"
    }
  },

  "radius": {
    "sm": 6,
    "md": 10,
    "lg": 14,
    "xl": 20,
    "code-block": 10,
    "full": 9999
  },

  "spacing": {
    "sidebar-width": 260,
    "chat-max-width": 720,
    "user-msg-max-width": "70%"
  },

  "motion": {
    "hover": "120ms",
    "click": "150ms",
    "dropdown": "180ms",
    "modal": "200ms",
    "theme-switch": "240ms",
    "easing": "cubic-bezier(0.25, 0.8, 0.25, 1)",
    "skeleton-duration": "1.6s",
    "skeleton-max-opacity": 0.1
  },

  "semantic": {
    "success": "#1F9D6B",
    "error": "#E0584B",
    "warning": "#D98E3B",
    "info": "#5B8DEF"
  },

  "themes": {
    "black-panther": {
      "default": true,
      "bg": "#020304",
      "text-ai": "#EDEAE3",
      "text-secondary": "#8A8378",
      "accent": "#C5A059",
      "neutrals": [
        "#020304", "#14130F", "#28251E", "#3D392E",
        "#5C5648", "#8A8378", "#C9C3B5", "#EDEAE3"
      ],
      "surface": "#14130F",
      "elevated": "#28251E",
      "input": "#14130F",
      "navbar": "rgba(2, 3, 4, 0.95)",
      "border": "rgba(197, 160, 89, 0.08)",
      "border-hover": "rgba(197, 160, 89, 0.16)",
      "code-bg": "#14130F",
      "code-header": "#28251E"
    },
    "obsidian": {
      "bg": "#050810",
      "text-ai": "#E4E7EC",
      "text-secondary": "#6B7280",
      "accent": "#00D4AA",
      "neutrals": [
        "#050810", "#0E1220", "#1A2030", "#2A3040",
        "#4A5060", "#6B7280", "#B0B8C4", "#E4E7EC"
      ],
      "surface": "#0E1220",
      "elevated": "#1A2030",
      "input": "#0A0F1A",
      "navbar": "rgba(5, 8, 16, 0.92)",
      "border": "rgba(0, 212, 170, 0.08)",
      "border-hover": "rgba(0, 212, 170, 0.16)",
      "code-bg": "#0E1220",
      "code-header": "#1A2030"
    },
    "bleu-nuit": {
      "bg": "#05081A",
      "text-ai": "#ECF0FF",
      "text-secondary": "#6B7DA0",
      "accent": "#3B82F6",
      "surface": "#0C1025",
      "elevated": "#141A35",
      "input": "#0C1025",
      "navbar": "rgba(5, 8, 26, 0.92)",
      "border": "rgba(59, 130, 246, 0.08)",
      "border-hover": "rgba(59, 130, 246, 0.16)",
      "code-bg": "#0C1025",
      "code-header": "#141A35"
    },
    "vert-foret": {
      "bg": "#06150C",
      "text-ai": "#E6F5EB",
      "text-secondary": "#6B8A72",
      "accent": "#1F9D6B",
      "surface": "#0C1F14",
      "elevated": "#142A1C",
      "input": "#0C1F14",
      "navbar": "rgba(6, 21, 12, 0.92)",
      "border": "rgba(31, 157, 107, 0.08)",
      "border-hover": "rgba(31, 157, 107, 0.16)",
      "code-bg": "#0C1F14",
      "code-header": "#142A1C"
    },
    "noir-oled": {
      "bg": "#000000",
      "text-ai": "#F0F0F0",
      "text-secondary": "#666666",
      "accent": "#C5A059",
      "surface": "#0A0A0A",
      "elevated": "#141414",
      "input": "#0A0A0A",
      "navbar": "rgba(0, 0, 0, 0.95)",
      "border": "rgba(197, 160, 89, 0.06)",
      "border-hover": "rgba(197, 160, 89, 0.12)",
      "code-bg": "#0A0A0A",
      "code-header": "#141414"
    },
    "blanc-emeraude": {
      "bg": "#F8FAF9",
      "text-ai": "#0A5C43",
      "text-secondary": "#56565C",
      "accent": "#B8922A",
      "surface": "#FFFFFF",
      "elevated": "#F0F4F2",
      "input": "#FFFFFF",
      "navbar": "rgba(248, 250, 249, 0.92)",
      "border": "rgba(10, 92, 67, 0.10)",
      "border-hover": "rgba(10, 92, 67, 0.18)",
      "code-bg": "#F0F4F2",
      "code-header": "#E5EBE9",
      "color-scheme": "light"
    }
  },

  "code-syntax": {
    "$description": "Palette désaturée dérivée des couleurs Gabon — pas de VS Code criard",
    "keyword": "#D98E3B",
    "string": "#1F9D6B",
    "comment": "#5C5648",
    "function": "#C5A059",
    "number": "#5B8DEF",
    "type": "#8A7A5E",
    "variable": "#C9C3B5",
    "operator": "#8A8378",
    "punctuation": "#5C5648"
  },

  "ansi-terminal": {
    "$description": "Mapping ANSI pour AgentTerminal",
    "green": "#1F9D6B",
    "red": "#E0584B",
    "yellow": "#D98E3B",
    "blue": "#5B8DEF",
    "cyan": "#00D4AA",
    "magenta": "#C5A059",
    "white": "#EDEAE3",
    "bright-white": "#FFFFFF"
  }
}
