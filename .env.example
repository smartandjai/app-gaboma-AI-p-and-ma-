# Fondateur: Daniel Jonathan ANDJ — SmartANDJ AI Technologies
# Stack complète 2026 — Copier vers .env.local et remplir
# =====================================================

# ─── CLERK (Auth) ─────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx

# ─── CLERK (Routes) ───────────────────────────────
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/chat
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/chat

# ─── NEON (PostgreSQL Serverless) ─────────────────
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:pass@host/db?sslmode=require
NEON_API_KEY=xxx

# ─── UPSTASH REDIS (Cache + Rate Limit) ───────────
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io:6379
UPSTASH_REDIS_REST_TOKEN=xxx

# ─── QSTASH (Queues) ─────────────────────────────
QSTASH_URL=https://qstash-xxx.upstash.io
QSTASH_TOKEN=xxx
QSTASH_CURRENT_SIGNING_KEY=sig_xxx
QSTASH_NEXT_SIGNING_KEY=sig_xxx

# ─── SENTRY (Crashes + Erreurs) ───────────────────
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.de.sentry.io/xxx
SENTRY_AUTH_TOKEN=sntrys_xxx
SENTRY_ORG=smartandj-ai-technologies
SENTRY_PROJECT=gaboma-ai-web

# ─── POSTHOG (Analytics + Session Replay) ─────────
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# ─── BETTER STACK (Logs + Uptime) ─────────────────
BETTERSTACK_SOURCE_TOKEN=xxx

# ─── GROQ (LLM Principal) ────────────────────────
GROQ_API_KEY=gsk_xxx

# ─── TAVILY (Web Search) ─────────────────────────
TAVILY_API_KEY=tvly-xxx

# ─── DEERFLOW (Agent) ────────────────────────────
DEERFLOW_API_BASE=http://localhost:8080
BASIC_MODEL__api_key=xxx
BASIC_MODEL__model=gemini-2.5-flash
BASIC_MODEL__base_url=https://generativelanguage.googleapis.com/v1beta/openai/

# ─── QDRANT (Vector DB) ──────────────────────────
QDRANT_URL=https://qdrant.northflank.app
QDRANT_API_KEY=xxx

# ─── RESEND (Email Transactionnel) ────────────────
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@gaboma.ai

# ─── LOOPS.SO (Email Marketing) ──────────────────
LOOPS_API_KEY=xxx

# ─── CLOUDFLARE R2 (Fichiers) ────────────────────
R2_ACCOUNT_ID=xxx
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx
R2_BUCKET_NAME=gaboma-uploads
R2_PUBLIC_URL=https://uploads.gaboma.ai

# ─── TRIGGER.DEV (Background Jobs) ───────────────
TRIGGER_API_KEY=tr_xxx
TRIGGER_API_URL=https://api.trigger.dev

# ─── CRISP (Support Chat) ────────────────────────
NEXT_PUBLIC_CRISP_WEBSITE_ID=xxx

# ─── URLS ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── FEATURE FLAGS ────────────────────────────────
FEATURE_FLAG_AGENT_ENABLED=true
FEATURE_FLAG_RAG_ENABLED=true

# ─── APP ──────────────────────────────────────────
APP_NAME=Gaboma AI
APP_ENV=development
NODE_ENV=development
